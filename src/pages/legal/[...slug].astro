---
import LegalPage from "../../Layouts/LegalPage.astro";

export async function getStaticPaths() {
  const legalEntries = import.meta.glob("../../content/legal/*.md", { eager: true });
  const entries = Object.values(legalEntries) as Array<{ frontmatter: Record<string, unknown> }>;

  return entries.map((entry) => ({
    params: { slug: String(entry.frontmatter.slug) },
    props: { entry: entry.frontmatter, slug: String(entry.frontmatter.slug) },
  }));
}

const { entry, slug } = Astro.props as { entry: Record<string, unknown>; slug: string };
---
<LegalPage {...entry} slug={slug} />
