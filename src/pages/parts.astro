---
import BaseHead from "../components/BaseHead.astro";
import ArrowButton from "../components/buttons/ArrowButton.astro";
import SkipMain from "../components/buttons/SkipMain.astro";
import CookiePopup from "../components/CookiePopup.astro";
import FooterMain from "../components/FooterMain.astro";
import PartsForm from "../components/forms/PartsForm.astro";
import LogoWrap from "../components/LogoWrap.astro";
import NavMain from "../components/NavMain.astro";
import ServiceBanner from "../components/ServiceBanner.astro";
import TestimonialCardWrap from "../components/TestimonialCardWrap.astro";
---

<!DOCTYPE html>
<html lang="en">
    <BaseHead 
        title="Golf Cart Parts | West Valley Golf Cars | Arizona's Trusted Dealer"
        description="Find high-quality parts for your golf cart at West Valley Golf Cars. We offer a wide range of golf cart parts and accessories to keep your cart running smoothly. Serving Arizona with the best golf cart parts since 2000."
        keywords="golf cart parts, golf cart accessories, golf cart batteries, golf cart tires, golf cart maintenance, West Valley, Arizona"
        image="/images/opengraph/open-graph_main2.webp"
        url="https://www.westvalleygolfcars.com/parts"
    />
    <body class="page-transition-enter">
        <SkipMain />
        <header>
            <NavMain data-aos="fade-down"/>
        </header>
        <main id="main-content">
            <section class="hero-home" data-aos="fade-up">
                <div class="top-banner"></div>
                <div class="background-image" aria-hidden="true"></div>
                <div class="padding-hero">
                    <div class="container">
                        <div class="wrapper column-hero">
                            <div class="wrapper">
                                <h1 class="page-title" data-aos="fade-up">Find the <span class="underline">Perfect</span> Parts for your golf cart</h1>
                                <p class="text" data-aos="fade-up">At West Valley Golf Cars, we understand the importance of keeping your golf cart in top condition. Our knowledgeable team is here to help you identify and source the right parts for any repair or upgrade. From batteries and tires to custom accessories, we have the expertise to guide you through the selection process, ensuring you get exactly what you need. Our commitment is to provide you with unparalleled support and advice, making it easy for you to maintain and enhance your golf cart's performance and appearance.</p>
                                <div class="btn-wrapper" data-aos="fade-up">
                                    <a href="#request" class="btn">Find Parts Today</a>
                                </div>
                            </div>
                            <img src="/images/static/service-image-2.webp" alt="2024 Madjax Blue Golf Cart" class="img-main hero" loading="eager" data-aos="fade-left" />
                        </div>
                    </div>
                </div>
            </section>
            
            <ServiceBanner data-aos="fade-up" />

            <section id="lithium-ion" data-aos="fade-up">
                <div class="padding-global">
                    <div class="container">
                        <LogoWrap 
                        logoSize="logo-large"
                        text="large-text" />
                        <div class="mt-8">
                            <div class="wrapper column vert-center">
                                <img src="/images/static/eco-battery.webp" alt="West Valley Golf Cars West Valley Edition" class="img-main" loading="lazy" data-aos="zoom-in"/>
                                <div class="wrapper" data-aos="fade-right">
                                    <h2 class="section-title">Upgrade to a <span class="underline">Lithium Ion</span> Battery for Your Golf Cart</h2>
                                    <p class="text">Lithium ion batteries represent the future of golf cart power systems, offering superior performance and reliability compared to traditional lead acid alternatives. Modern lithium technology delivers exceptional efficiency, faster charging times, and significantly extended lifespan. Often lasting 10 times longer than conventional batteries while taking up less space and weighing considerably less, lithium ion batteries eliminate the bulk and weight that traditionally burdened golf cart owners.</p>
                                    <p class="text">Beyond the practical benefits, upgrading to lithium ion batteries means fewer maintenance headaches, consistent power delivery in all weather conditions, and the peace of mind that comes with a dependable energy solution. Whether you're a frequent golfer or rely on your cart for daily transportation, lithium ion batteries provide the reliable power you need to maximize your time enjoying your cart rather than managing battery concerns. Make the smart switch to lithium ion technology and experience the difference that modern battery innovation can make. Contact us today to schedule a service appointment and learn how we can help you upgrade your golf cart's power system.</p>
                                    <ArrowButton slug="/service/#schedule" aria="Schedule a Service" text="Schedule A Service" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section>
                <div class="padding-global" data-aos="fade-up">
                    <div class="container">
                        <h2 class="section-title center">What Our <span class="underline">Customers</span> Are Saying</h2>
                        <TestimonialCardWrap data-aos="fade-up" />
                    </div>
                </div>
            </section>

            <section id="request" data-aos="fade-up">
                <div class="padding-global">
                    <div class="container">
                        <h2 class="section-title center">Let's Find the <span class="underline">Right Parts</span> for Your Cart</h2>
                        <PartsForm data-aos="fade-up"/>
                    </div>
                </div>
            </section>
        </main>

        <footer>
            <FooterMain />
        </footer>
        <CookiePopup />
    </body>

    <script type="module">
        import * as AOS from 'aos';
        import 'aos/dist/aos.css';
    
        const initializeAOS = () => {
            if (window.innerWidth > 980) {
                AOS.init({
                    duration: 800,
                    once: true,
                    easing: 'ease-in-out',
                    offset: 0,
                    delay: 0,
                });
            } else {
                const aosElements = document.querySelectorAll('[data-aos]');
                aosElements.forEach((element) => {
                    element.removeAttribute('data-aos');
                    element.style.opacity = '1';
                    element.style.transform = 'none';
                });
            }
        };
    
        // Initialize AOS on initial page load
        document.addEventListener('DOMContentLoaded', () => {
            initializeAOS();
        });
    
        // Reinitialize AOS on back/forward navigation
        window.addEventListener('popstate', () => {
            // Ensure scroll restoration is handled
            window.scrollTo(0, 0);
    
            // Reinitialize AOS animations
            initializeAOS();
        });
    </script>    
</html>