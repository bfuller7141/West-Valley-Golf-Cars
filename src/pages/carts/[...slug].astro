---
import CartPage from "../../Layouts/CartPage.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const cartEntries = await getCollection('carts');
  return cartEntries.map((cart) => ({
    params: { slug: cart.id },
    props: { cart, slug: cart.id },
  }));
}

const { cart, slug } = Astro.props as { cart: CollectionEntry<'carts'>; slug: string };
const { Content } = await render(cart);
---
<CartPage {...cart.data} slug={slug}>
  <Content />
</CartPage>
