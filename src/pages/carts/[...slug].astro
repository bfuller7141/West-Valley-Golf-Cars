---
import CartPage from "../../Layouts/CartPage.astro";

export async function getStaticPaths() {
  const cartEntries = import.meta.glob("../../content/carts/*.md", { eager: true });
  const carts = Object.values(cartEntries) as Array<{ frontmatter: Record<string, unknown> }>;

  return carts.map((cart) => ({
    params: { slug: String(cart.frontmatter.slug) },
    props: { cart: cart.frontmatter, slug: String(cart.frontmatter.slug) },
  }));
}

const { cart, slug } = Astro.props as { cart: Record<string, unknown>; slug: string };
---
<CartPage {...cart} slug={slug} />
